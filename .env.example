# ============================================================
# .env.example — 所有需要的環境變數
# 複製為 .env 並填寫你自己的值
# ============================================================

# Gmail（用於 send_email / crontab_monitor 告警郵件）
GMAIL_USERNAME=
GMAIL_APP_PASSWORD=
GMAIL_RECIPIENTS=

# OpenCode Server（用於 observer / reflector / newsletter / crontab_monitor）
OPENCODE_BASE_URL=http://localhost:4096
OPENCODE_PASSWORD=
OPENCODE_USERNAME=opencode

# Anthropic API（用於 v1 capture triage）
ANTHROPIC_API_KEY=

# Google OAuth（用於 v1 capture 讀取 Calendar / Gmail）
# GOOGLE_CREDENTIALS：OAuth 2.0 credentials.json 路徑（從 Google Cloud Console 下載）
GOOGLE_CREDENTIALS=
# GOOGLE_CAL_TOKEN：Calendar OAuth token 路徑（首次執行 capture.py 後自動生成）
GOOGLE_CAL_TOKEN=
# GOOGLE_GMAIL_TOKEN：Gmail OAuth token 路徑（首次執行 capture.py 後自動生成）
GOOGLE_GMAIL_TOKEN=

# Google Analytics 4（用於 ga4_metrics.py）
GA4_PROPERTY_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# Kit / ConvertKit（用於 kit_metrics.py 和 newsletter 釋出）
KIT_API_KEY=

# Typefully（用於 typefully_metrics.py，需從瀏覽器抓取）
TYPEFULLY_AUTHORIZATION=
TYPEFULLY_ACCOUNT=
TYPEFULLY_SESSION=

# Gemini（用於圖片生成）
GEMINI_API_KEY=

# OpenAI（用於 semantic_search 本地 embedding）
OPENAI_API_KEY=
